{
  "name": "nexus-ai-gateway",
  "version": "1.0.0",
  "description": "Production-ready AI Gateway with circuit breaker, graceful shutdown, and health-aware load balancing (2026)",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun --watch run index.ts",
    "build": "bun build ./index.ts --target=bun --outdir=./dist --minify",
    "start:prod": "bun run ./dist/index.js",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.3",
    "openai": "^4.104.0",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
